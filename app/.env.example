# ============================================================
# solo-eikaiwa の env は「API キーのみ」（v0.29〜）
# プロバイダ・モデル・BaseURL・TTS 等の設定はすべて UI（⚙️ 設定）で行う。
# ============================================================

# TTS/STT 用（OpenAI TTS を使う場合。ローカルTTSなら不要）
OPENAI_API_KEY=

# ローカルLLM（OpenAI 互換）のうち鍵が要るエンドポイント（OpenAI API / GitHub Models 等）のみ
OPENAI_COMPAT_API_KEY=

# Claude / Codex を API キーモード（サブスクではなく従量課金）で使う場合のみ
ANTHROPIC_API_KEY=
CODEX_API_KEY=

# TTS 専用の鍵（未指定なら OPENAI_API_KEY にフォールバック）
TTS_API_KEY=

# ------------------------------------------------------------
# 以下は教材生成 CLI（scripts/generate-content.ts 等）専用。
# アプリ本体（サーバ/UI）はこれらを一切読まない。
# ------------------------------------------------------------
# CLI のプロバイダ: claude | openai-compat | codex（未設定は claude）
LLM_PROVIDER=
# LLM_PROVIDER=openai-compat のとき
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_MODEL=
# LLM_PROVIDER=codex のとき（任意・未指定は codex config の既定モデル）
CODEX_MODEL=
# CLI 用チューニング
# claude: モデルは haiku|sonnet|opus・effort は low|medium|high|xhigh|max
CLAUDE_MODEL=
CLAUDE_EFFORT=
# codex: effort は low|medium|high|xhigh（未指定 medium）・tier は fast|standard（未指定 fast）
CODEX_REASONING_EFFORT=
CODEX_SERVICE_TIER=
